---
import Layout from "@/layouts/Layout.astro";
import Toc from "@/components/widgets/Toc.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const headings = [
  { depth: 2, slug: "about-lab", text: "About the Lab" },
  { depth: 2, slug: "professor", text: "Professor" },
  { depth: 2, slug: "projects", text: "Projects & Collaborations" },
  { depth: 2, slug: "awards", text: "Awards" },
  { depth: 2, slug: "contact", text: t('contact.title') },
];

const filtered = headings.filter(h => h.depth <= 3);
---

<Layout title="About – TYLin Lab">
  <!-- Mobile TOC -->
  <div class="block lg:hidden px-7 pt-6">
    <Toc headings={filtered} />
  </div>

  <div class="relative site-container mx-auto my-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">
      <!-- Left TOC -->
      <aside class="relative hidden lg:block lg:w-44 xl:w-52 flex-shrink-0">
        <div class="toc-sticky-wrapper">
          <Toc headings={filtered} />
        </div>
      </aside>

      <!-- Main Content -->
      <main class="relative flex-1 min-w-0 w-full lg:max-w-none">

        <!-- About Lab -->
        <section id="about-lab" class="mb-16 scroll-mt-24" data-aos="fade-up-xs" data-aos-duration="500" data-aos-once="true">
          <h2 class="text-2xl font-brand tracking-tight sm:text-3xl lg:text-4xl mb-6">About TYLin Lab</h2>
          <div class="prose dark:prose-invert max-w-none text-neutral-700 dark:text-neutral-300 leading-relaxed space-y-4">
            <p>
              TYLin Lab（林姿瑩實驗室）隸屬於國立清華大學材料科學工程學系，專注於能源材料與薄膜光伏技術的研發。實驗室的研究涵蓋兩大核心領域：<strong>永續能源儲存材料</strong>（鋰/鈉離子電池正負極材料、固態與複合電解質）與<strong>薄膜化合物光伏技術</strong>（CIGS太陽能電池、鹼金屬處理、太空輻射穩定性）。
            </p>
            <p>
              TYLin Lab, part of the Department of Materials Science and Engineering at National Tsing Hua University, focuses on energy materials and thin-film photovoltaic technology. Our research spans two core areas: <strong>sustainable energy storage materials</strong> for Li/Na-ion batteries and <strong>thin-film compound photovoltaics</strong> (CIGS solar cells) for terrestrial and space applications.
            </p>
          </div>
        </section>

        <!-- Professor -->
        <section id="professor" class="mb-16 scroll-mt-24" data-aos="fade-up-xs" data-aos-duration="500" data-aos-once="true">
          <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 pb-3 border-b border-neutral-200 dark:border-neutral-700">Professor</h2>
          <div class="flex flex-col md:flex-row gap-8 p-6 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white/50 dark:bg-neutral-900/50">
            <div class="w-40 h-48 md:w-48 md:h-56 rounded-xl bg-neutral-200 dark:bg-neutral-800 flex-shrink-0 flex items-center justify-center overflow-hidden border border-neutral-200 dark:border-neutral-700">
              <img 
                src="/assets/members/prof-lin.jpg" 
                alt="Prof. Tzu-Ying Lin" 
                class="w-full h-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden text-5xl">👩‍🔬</div>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-semibold text-neutral-800 dark:text-neutral-200">林姿瑩 Prof. Tzu-Ying Lin</h3>
              <p class="text-neutral-500 dark:text-neutral-400 mt-1">Associate Professor</p>
              <p class="text-neutral-500 dark:text-neutral-400">Department of Materials Science and Engineering</p>
              <p class="text-neutral-500 dark:text-neutral-400 mb-4">National Tsing Hua University (NTHU)</p>
              <div class="space-y-1 text-sm text-neutral-600 dark:text-neutral-400">
                <p>📧 tzuying.lin@mx.nthu.edu.tw</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Projects & Collaborations -->
        <section id="projects" class="mb-16 scroll-mt-24" data-aos="fade-up-xs" data-aos-duration="500" data-aos-once="true">
          <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 pb-3 border-b border-neutral-200 dark:border-neutral-700">Projects & Collaborations</h2>

          <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4 text-neutral-800 dark:text-neutral-200">產學合作 Industry-Academia Collaboration</h3>
            <!-- Marquee Container -->
            <div class="relative flex overflow-hidden group py-6">
              <!-- Gradient Masks for smooth fade out at edges -->
              <div class="pointer-events-none absolute inset-y-0 left-0 w-[15%] bg-gradient-to-r from-[#F6F5F2] dark:from-[#1A1A1A] to-transparent z-10"></div>
              <div class="pointer-events-none absolute inset-y-0 right-0 w-[15%] bg-gradient-to-l from-[#F6F5F2] dark:from-[#1A1A1A] to-transparent z-10"></div>
              
              <!-- Track 1 -->
              <div class="flex flex-nowrap animate-[marquee_25s_linear_infinite] group-hover:[animation-play-state:paused] items-center shrink-0 w-max">
                <!-- 合作夥伴 1 -->
                <a href="https://www.itri.org.tw/index.aspx" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-1.png" alt="Collaborator 1" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>
                
                <!-- 合作夥伴 2 -->
                <a href="https://www.nsrrc.org.tw/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-2.png" alt="Collaborator 2" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <!-- 合作夥伴 3 -->
                <a href="https://www.um.edu.my/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-3.png" alt="Collaborator 3" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <!-- 合作夥伴 4 -->
                <a href="https://www.tus.ac.jp/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-4.png" alt="Collaborator 4" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <!-- 合作夥伴 5 -->
                <a href="https://www.empa.ch/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-5.png" alt="Collaborator 5" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>
              </div>

              <!-- Track 2 (Duplicate for seamless loop) -->
              <div class="flex flex-nowrap animate-[marquee_25s_linear_infinite] group-hover:[animation-play-state:paused] items-center shrink-0 w-max" aria-hidden="true">
                <!-- 將上面的圖片再一次複製，才能無縫接軌 -->
                <a href="https://www.itri.org.tw/index.aspx" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-1.png" alt="Collaborator 1" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>
                
                <a href="https://www.nsrrc.org.tw/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-2.png" alt="Collaborator 2" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <a href="https://www.um.edu.my/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-3.png" alt="Collaborator 3" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <a href="https://www.tus.ac.jp/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-4.png" alt="Collaborator 4" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>

                <a href="https://www.empa.ch/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
                  <img src="/assets/home/partner-5.png" alt="Collaborator 5" class="h-12 md:h-16 w-auto object-contain max-w-none" />
                </a>
              </div>
            </div>
          </div>

        </section>

        <!-- Awards -->
        <section id="awards" class="mb-16 scroll-mt-24" data-aos="fade-up-xs" data-aos-duration="500" data-aos-once="true">
          <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 pb-3 border-b border-neutral-200 dark:border-neutral-700">Awards</h2>
          <div class="p-8 rounded-xl border border-dashed border-neutral-300 dark:border-neutral-600 text-center text-neutral-400 dark:text-neutral-500">
            <p class="text-sm">Information coming soon / 資料準備中</p>
          </div>
        </section>

        <!-- Contact -->
        <section id="contact" class="mb-16 scroll-mt-24" data-aos="fade-up-xs" data-aos-duration="500" data-aos-once="true">
          <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 pb-3 border-b border-neutral-200 dark:border-neutral-700">{t('contact.title')}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="p-6 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white/50 dark:bg-neutral-900/50">
              <h3 class="font-semibold text-lg mb-4 text-neutral-800 dark:text-neutral-200">{t('contact.labLocation')}</h3>
              <div class="space-y-4 text-sm text-neutral-600 dark:text-neutral-400">
                <div>
                  <p class="font-medium text-neutral-800 dark:text-neutral-200 mb-1">【{t('footer.teacherOffice')}】</p>
                  <p>{t('footer.buildingD')} 413{t('footer.room')} ({t('footer.ext')}: 35341)</p>
                </div>
                <div>
                  <p class="font-medium text-neutral-800 dark:text-neutral-200 mb-1">【{t('footer.studentOffice')}】</p>
                  <p>1. {t('footer.buildingMSE')} 102{t('footer.room')} ({t('footer.ext')}: 35343)</p>
                  <p>2. {t('footer.buildingEng3')} 221{t('footer.room')} ({t('footer.ext')}: 35367)</p>
                </div>
                <div class="pt-2 border-t border-neutral-100 dark:border-neutral-800">
                  <p>{t('contact.department')}</p>
                  <p>{t('contact.university')}</p>
                  <p>{t('contact.address1')}</p>
                  <p>{t('contact.address2')}</p>
                </div>
              </div>
            </div>
            <div class="p-6 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white/50 dark:bg-neutral-900/50">
              <h3 class="font-semibold text-lg mb-4 text-neutral-800 dark:text-neutral-200">{t('contact.getInTouch')}</h3>
              <div class="space-y-3 text-sm text-neutral-600 dark:text-neutral-400">
                <p>
                  <span class="font-medium">Prof. Tzu-Ying Lin</span>
                </p>
                <p>📧 Email: <a href="mailto:tzuying.lin@mx.nthu.edu.tw" class="text-blue-600 dark:text-blue-400 hover:underline">tzuying.lin@mx.nthu.edu.tw</a></p>
                <p>☎️ Extension: 35341</p>
              </div>
            </div>
          </div>
        </section>

      </main>
    </div>
  </div>
</Layout>
