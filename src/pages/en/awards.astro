---

<Layout
  title="Awards – TYLin Lab"
  description="Honors and awards received by members of TYLin Lab at National Tsing Hua University."
  keywords="awards, honors, TYLin Lab, NTHU, research"
>
  <div class="site-container mx-auto px-4 mt-8 mb-16 max-w-4xl">
    <div class="mb-12 pb-4 border-b border-neutral-200 dark:border-neutral-800">
      <h1 class="text-3xl font-brand tracking-tight sm:text-4xl text-neutral-900 dark:text-neutral-100 mb-4">
        Honors & Awards
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Celebrating the achievements and recognition of our lab members.
      </p>
    </div>

    <div class="flex flex-col gap-6">
      {awardsItems.map((item, index) => (
        <div class="flex flex-col p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white/40 dark:bg-neutral-900/40 hover:bg-neutral-50 dark:hover:bg-neutral-800/60 transition-colors shadow-sm">
          <div class="mb-2">
            <span class="text-sm font-medium text-pri-dark dark:text-pri">{item.date}</span>
          </div>
          <div class="flex-1 flex flex-col justify-center">
            <h2 class="text-lg font-bold text-neutral-800 dark:text-neutral-200 mb-2 leading-snug">
              {item.zh.replace("恭喜", "").replace("。", "")}
            </h2>
            <p class="text-neutral-600 dark:text-neutral-400 italic text-sm">
              {item.en.replace("Congratulations that ", "")}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
