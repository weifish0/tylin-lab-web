---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import AnimatedText from "@/components/ui/AnimatedText.astro";
import HeroCarousel from "@/components/home/HeroCarousel.astro";
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 取得所有 news 並依據 date 排序 (新 -> 舊)
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
}).slice(0, 4); // 首頁只取最新 4 筆
---

<Layout
  keywords="TYLin Lab, CIGS, solar cells, lithium-ion battery, solid-state electrolyte, NTHU, 林姿瑩"
>
  <div class="relative site-container z-20 w-full mx-auto mt-4 px-4 md:mt-8 lg:mt-10 xl:px-0">
    <!-- Hero Section -->
    <div class="relative w-full px-2 md:px-4 flex flex-col items-center justify-center mb-16 text-center">
      <div class="relative w-full max-w-7xl flex justify-center">
        <div class="w-full lg:w-[90%]">
          <HeroCarousel />
        </div>
      </div>
    </div>
  </div>

  <!-- News Section -->
  <section
    class="site-container mx-auto px-4 mt-8 mb-16"
    data-aos="fade-up-sm"
    data-aos-delay="50"
    data-aos-duration="600"
    data-aos-once="true"
  >
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-neutral-200 dark:border-neutral-800">
      <h2 class="text-2xl font-brand tracking-tight sm:text-3xl flex items-center gap-2">
        <span class="text-pri">{t('home.latestNews')}</span>
      </h2>
      <a href={getRelativeLocaleUrl(lang, "/news")} class="text-sm font-medium text-neutral-500 hover:text-pri transition-colors">{t('home.seeAllNews')}</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative">
      {sortedNews.map((newsItem) => (
        <a href={`/news/${newsItem.id}`} class="flex flex-col p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white/40 dark:bg-neutral-900/40 hover:bg-neutral-50 dark:hover:bg-neutral-800/60 transition-colors shadow-sm">
          <div class="mb-2">
            <span class="text-sm font-medium text-pri-dark dark:text-pri">{newsItem.data.date}</span>
          </div>
          <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200 mb-2 leading-snug">
            {newsItem.data.title}
          </h3>
          <p class="text-neutral-600 dark:text-neutral-400 text-sm line-clamp-2">
            {newsItem.data.description}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- Research Highlights -->
  <section
    class="site-container mx-auto px-4 mt-20 mb-12"
    data-aos="fade-up-sm"
    data-aos-delay="100"
    data-aos-duration="600"
    data-aos-once="true"
  >
    <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 text-center">{t('home.researchAreas')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Battery Research -->
      <a href="/research#battery" class="group block p-6 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white/50 dark:bg-neutral-900/50 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-600 dark:text-green-400 text-xl">⚡</div>
          <h3 class="text-xl font-semibold text-neutral-800 dark:text-neutral-200">Sustainable Energy Storage</h3>
        </div>
        <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
          Developing sustainable energy storage materials and technologies—from waste-derived anodes and high-performance cathodes to solid-state and composite electrolyte systems for next-generation Li/Na-ion batteries.
        </p>
      </a>

      <!-- Solar Research -->
      <a href="/research#solar" class="group block p-6 rounded-2xl border border-neutral-200 dark:border-neutral-700 bg-white/50 dark:bg-neutral-900/50 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400 text-xl">☀️</div>
          <h3 class="text-xl font-semibold text-neutral-800 dark:text-neutral-200">Thin-Film Compound Photovoltaics</h3>
        </div>
        <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
          CIGS solar cells with chalcopyrite structure for lightweight, flexible, and radiation-tolerant photovoltaic applications—including alkali metal treatments, space radiation stability, and photoelectrode development.
        </p>
      </a>
    </div>
  </section>

  <!-- Partners Marquee / Quick Links replacement -->
  <section
    class="site-container mx-auto mt-16 mb-20 overflow-hidden relative w-full"
    data-aos="fade-up-sm"
    data-aos-delay="100"
    data-aos-duration="600"
    data-aos-once="true"
  >
    <h2 class="text-2xl font-brand tracking-tight sm:text-3xl mb-8 text-center bg-clip-text text-transparent bg-gradient-to-r from-neutral-800 to-neutral-500 dark:from-neutral-200 dark:to-neutral-500">
      {t('home.collaborators')}
    </h2>
    
    <!-- Marquee Container -->
    <div class="relative flex overflow-hidden group">
      <!-- Gradient Masks for smooth fade out at edges -->
      <div class="pointer-events-none absolute inset-y-0 left-0 w-[15%] bg-gradient-to-r from-[#F6F5F2] dark:from-[#1A1A1A] to-transparent z-10"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-[15%] bg-gradient-to-l from-[#F6F5F2] dark:from-[#1A1A1A] to-transparent z-10"></div>
      
      <!-- Track 1 -->
      <div class="flex flex-nowrap animate-[marquee_25s_linear_infinite] group-hover:[animation-play-state:paused] items-center shrink-0 w-max">
        <!-- 合作夥伴 1 -->
        <a href="https://www.itri.org.tw/index.aspx" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-1.png" alt="Collaborator 1" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>
        
        <!-- 合作夥伴 2 -->
        <a href="https://www.nsrrc.org.tw/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-2.png" alt="Collaborator 2" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <!-- 合作夥伴 3 -->
        <a href="https://www.um.edu.my/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-3.png" alt="Collaborator 3" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <!-- 合作夥伴 4 -->
        <a href="https://www.tus.ac.jp/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-4.png" alt="Collaborator 4" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <!-- 合作夥伴 5 -->
        <a href="https://www.empa.ch/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-5.png" alt="Collaborator 5" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>
      </div>

      <!-- Track 2 (Duplicate for seamless loop) -->
      <div class="flex flex-nowrap animate-[marquee_25s_linear_infinite] group-hover:[animation-play-state:paused] items-center shrink-0 w-max" aria-hidden="true">
        <!-- 將上面的圖片再一次複製，才能無縫接軌 -->
        <a href="https://www.itri.org.tw/index.aspx" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-1.png" alt="Collaborator 1" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>
        
        <a href="https://www.nsrrc.org.tw/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-2.png" alt="Collaborator 2" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <a href="https://www.um.edu.my/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-3.png" alt="Collaborator 3" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <a href="https://www.tus.ac.jp/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-4.png" alt="Collaborator 4" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>

        <a href="https://www.empa.ch/" target="_blank" rel="noopener noreferrer" class="mx-6 md:mx-10 shrink-0 opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 flex items-center justify-center">
          <img src="/assets/home/partner-5.png" alt="Collaborator 5" class="h-12 md:h-16 w-auto object-contain max-w-none" />
        </a>
      </div>
    </div>
  </section>
</Layout>
