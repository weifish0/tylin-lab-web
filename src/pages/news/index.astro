---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<Layout
  title="News – TYLin Lab"
  description="Latest news and updates from TYLin Lab at National Tsing Hua University."
  keywords="news, updates, TYLin Lab, NTHU"
>
  <div class="site-container mx-auto px-4 mt-8 mb-16 max-w-4xl">
    <div class="mb-12 pb-4 border-b border-neutral-200 dark:border-neutral-800">
      <h1 class="text-3xl font-brand tracking-tight sm:text-4xl text-neutral-900 dark:text-neutral-100 mb-4">
        News & Updates
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        The latest achievements, awards, and events from our lab.
      </p>
    </div>

    <div class="flex flex-col gap-6">
      {sortedNews.map((newsItem) => (
        <a href={`/news/${newsItem.id}`} class="flex flex-col p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white/40 dark:bg-neutral-900/40 hover:bg-neutral-50 dark:hover:bg-neutral-800/60 transition-colors shadow-sm">
          <div class="mb-2">
            <span class="text-sm font-medium text-pri-dark dark:text-pri">{newsItem.data.date}</span>
          </div>
          <div class="flex-1 flex flex-col justify-center">
            <h2 class="text-lg font-bold text-neutral-800 dark:text-neutral-200 mb-2 leading-snug">
              {newsItem.data.title}
            </h2>
            <p class="text-neutral-600 dark:text-neutral-400 text-sm">
              {newsItem.data.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
