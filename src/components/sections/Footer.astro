---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig } from "@/config/site.js";
---

<section
  class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]"
>
  <div
    class="container flex flex-col items-center py-8 mx-auto px-7 max-w-7xl sm:flex-row"
  >
    <div class="flex flex-col items-center sm:items-start gap-3">
      <div class="flex items-center gap-3">
        <Logo />
        <p
          class="text-sm text-neutral-700 dark:text-neutral-100 sm:ml-4 sm:pl-4 sm:border-l sm:border-neutral-300 dark:sm:border-neutral-700"
        >
          © {new Date().getFullYear()} TYLin Lab, Dept. of MSE, National Tsing Hua University
        </p>
      </div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400 sm:ml-4 flex flex-col sm:flex-row items-center sm:gap-4 mt-2 sm:mt-0">
        <span class="flex items-center gap-1.5 mb-1 sm:mb-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
           學生辦公室：材料實驗館 102室
        </span>
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
           分機號碼：#35343
        </span>
      </div>
    </div>
    
    <span
      class="inline-flex justify-center mt-6 space-x-4 sm:ml-auto sm:mt-0 sm:justify-start text-sm text-neutral-500 dark:text-neutral-400"
    >
      <a href="mailto:tzuying.lin@mx.nthu.edu.tw" class="hover:text-primary transition-colors flex items-center gap-1.5" title="Email: tzuying.lin@mx.nthu.edu.tw">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span>tzuying.lin@mx.nthu.edu.tw</span>
      </a>
    </span>
  </div>
</section>

<ToTop />