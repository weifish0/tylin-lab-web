---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentLang = lang;

// Helper function to replace language prefix in the current URL
const getUrlForLang = (targetLang: string) => {
  const currentPath = Astro.url.pathname;
  const basePath = currentPath.replace(/^\/(en|ja)/, '') || '/';
  
  if (targetLang === 'zh') return basePath;
  return `/${targetLang}${basePath === '/' ? '' : basePath}`;
};
---

<div class="relative group inline-block z-50 has-lang-dropdown">
  <button aria-label="Language Selector" class="btn-lang-toggle flex items-center justify-center w-10 h-10 rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors text-zinc-700 dark:text-zinc-300">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="2 12h20"/></svg>
  </button>
  {/* The pt-2 (padding-top) acts as a hover bridge so that there's no gap between the button and the dropdown to lose hover state */}
  <div class="lang-dropdown absolute right-0 top-full pt-2 hidden sm:group-hover:block w-[120px]">
    <div class="bg-white dark:bg-zinc-800 shadow-lg rounded-xl border border-zinc-200 dark:border-zinc-700 overflow-hidden">
      <a href={getUrlForLang('zh')} class={`block px-4 py-2.5 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors ${currentLang === 'zh' ? 'text-primary font-bold bg-zinc-50 dark:bg-zinc-700/50' : 'text-zinc-700 dark:text-zinc-300'}`}>繁體中文</a>
      <a href={getUrlForLang('en')} class={`block px-4 py-2.5 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors ${currentLang === 'en' ? 'text-primary font-bold bg-zinc-50 dark:bg-zinc-700/50' : 'text-zinc-700 dark:text-zinc-300'}`}>English</a>
      <a href={getUrlForLang('ja')} class={`block px-4 py-2.5 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors ${currentLang === 'ja' ? 'text-primary font-bold bg-zinc-50 dark:bg-zinc-700/50' : 'text-zinc-700 dark:text-zinc-300'}`}>日本語</a>
    </div>
  </div>
</div>

<script>
  // Handle mobile click toggle mapping
  const dropdownContainers = document.querySelectorAll('.has-lang-dropdown');
  
  dropdownContainers.forEach(container => {
    const btn = container.querySelector('.btn-lang-toggle');
    const menu = container.querySelector('.lang-dropdown');
    
    if (btn && menu) {
      btn.addEventListener('click', (e) => {
        // Prevent event from bubbling to document which closes the menu
        e.stopPropagation();
        
        // Toggle the hidden class specifically on this menu
        menu.classList.toggle('hidden');
        
        // Close other language dropdowns if they exist
        dropdownContainers.forEach(otherContainer => {
          if (otherContainer !== container) {
            otherContainer.querySelector('.lang-dropdown')?.classList.add('hidden');
          }
        });
      });
    }
  });

  // Close when clicking anywhere else
  document.addEventListener('click', () => {
    dropdownContainers.forEach(container => {
      const menu = container.querySelector('.lang-dropdown');
      if (menu) {
        menu.classList.add('hidden');
      }
    });
  });
</script>